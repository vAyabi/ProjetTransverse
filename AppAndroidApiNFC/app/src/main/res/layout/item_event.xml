<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="4dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/eventTitleTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:text="Titre de l'événement"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/eventDateTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Du 01/01/2025 au 02/01/2025"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/eventTypeTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Type: Webinar"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/eventPrestatairTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Par: Nom du prestataire"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
